    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "discord.js": "^14.25.1",
    "dotenv": "^17.2.3",
    "locutus": "^2.0.38",
    "mathjs": "^15.1.0",
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.0",
    "mongodb": "^7.0.0",
    "mongoose": "^9.1.5",
    "ms": "^2.1.3",
    "node-schedule": "^2.1.1",
    "npm-check-updates": "^19.3.2",
    "pagination.djs": "^4.0.18",
    "pm2": "^6.0.14",
    "powershell": "^2.3.3",
