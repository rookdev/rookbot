{
  "name": "rookbot",
  "version": "1.6",
  "description": "Discord bot for personal usage",
  "main": "src/index.js",
  "scripts": {
    "audit": "node ./src/res/ci/common/run-audit.js",
    "local-install": "node ./src/res/ci/common/run-install.js",
    "menu": "node ./src/res/ci/common/menu.js",
    "run": "node ./run.js",
    "update": "node ./src/res/ci/common/run-update.js",
    "ver": "node ./src/res/ci/common/ver.js",
    "castle-dev": "node ./crun.js --cu castle -p castle",
    "minnie-dev": "node ./crun.js --cu minnie -p minnie",
    "nikose-dev": "node ./crun.js --cu nikose -p nikose",
    "navy-dev": "node ./crun.js -s doinavy",
    "rook-dev": "node ./crun.js -s rookdev",
    "gitrook-dev": "node ./crun.js -p gitrook -l",
    "castle-prod": "node ./crun.js --cu castle -p castle -e prod",
    "minnie-prod": "node ./crun.js --cu minnie -p minnie -e prod",
    "nikose-prod": "node ./crun.js --cu nikose -p nikose -e prod",
    "navy-prod": "node ./crun.js -s doinavy -e prod",
    "rook-prod": "node ./crun.js -s rookdev -e prod -l",
    "gitrook-prod": "node ./crun.js -u gitrook -e prod -l",
    "minnie-gha": "node ./crun.js -cu minnie -e github",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
