{
  "stack": [
    "open-base-override",
    "private-base-override",
    "access-base-override",
    "member-write-override",
    "captain-mod-override",
    "mod-mod-override",
    "admin-admin-override"
  ],
  "open-base-override": {
    "description": [
      "Open Membership Base",
      "No invites"
    ],
    "profiles": {
      "open-base-override": {
        "CreateInstantInvite": false
      }
    }
  },
  "private-base-override": {
    "description": [
      "Private Channel Base",
      "No invites, can't view"
    ],
    "profiles": {
      "dependencies": [
        "open-base-override"
      ],
      "private-base-override": {
        "ViewChannel": false,
        "Connect": false
      }
    }
  },
  "access-base-override": {
    "description": [
      "Access Membership Base",
      "Alias for private-base-override"
    ],
    "profiles": {
      "dependencies": [
        "open-base-override",
        "private-base-override"
      ],
      "access-base-override": {}
    }
  },
  "readonly-override": {
    "description": [
      "Read-only Override",
      "Can view, connect"
    ],
    "profiles": {
      "dependencies": [
        "open-base-override",
        "private-base-override",
        "access-base-override"
      ],
      "readonly-override": {
        "ViewChannel": true,
        "Connect": true,
        "SendMessages": false,
        "SendMessagesInThreads": false,
        "CreatePublicThreads": false,
        "CreatePrivateThreads": false,
        "AddReactions": false,
        "UseExternalEmojis": false,
        "SendVoiceMessages": false,
        "SendPolls": false,
        "Speak": false,
        "Stream": false,
        "UseSoundboard": false,
        "UseApplicationCommands": false,
        "UseEmbeddedActivities": false,
        "UseExternalApps": false,
        "CreateEvents": false
      }
    }
  },
  "member-write-override": {
    "description": [
      "Member Override",
      "Can send messages, create threads, react,",
      "speak, stream, use app commands"
    ],
    "profiles": {
      "dependencies": [
        "open-base-override",
        "private-base-override",
        "access-base-override",
        "readonly-override"
      ],
      "member-write-override": {
        "SendMessages": true,
        "SendMessagesInThreads": true,
        "CreatePublicThreads": true,
        "CreatePrivateThreads": true,
        "AddReactions": true,
        "Speak": true,
        "Stream": true,
        "UseApplicationCommands": true
      }
    }
  },
  "captain-mod-override": {
    "description": [
      "Captain Override",
      "Can manage/pin messages, send polls, mute/deafen/move members",
      "Create/manage events"
    ],
    "profiles": {
      "dependencies": [
        "open-base-override",
        "private-base-override",
        "access-base-override",
        "readonly-override",
        "member-write-override"
      ],
      "captain-mod-override": {
        "ManageMessages": true,
        "PinMessages": true,
        "SendPolls": true,
        "MuteMembers": true,
        "DeafenMembers": true,
        "MoveMembers": true,
        "CreateEvents": true,
        "ManageEvents": true
      }
    }
  },
  "mod-mod-override": {
    "description": [
      "Moderator Override",
      "Can use external emojis, send TTS/voice messages,",
      "Use soundboard, embedded activities, external apps"
    ],
    "profiles": {
      "dependencies": [
        "open-base-override",
        "private-base-override",
        "access-base-override",
        "readonly-override",
        "member-write-override",
        "captain-mod-override"
      ],
      "mod-mod-override": {
        "UseExternalEmojis": true,
        "SendTTSMessages": true,
        "SendVoiceMessages": true,
        "UseSoundboard": true,
        "UseEmbeddedActivities": true,
        "UseExternalApps": true
      }
    }
  },
  "admin-admin-override": {
    "description": "Admin Override",
    "profiles": {
      "admin-admin-override": {
        "ViewChannel": true
      }
    }
  },
  "access-welcome-stack": {
    "description": "Welcome Channel",
    "profiles": {
      "@everyone":  "readonly-override",
      "muted":      "private-base-override",
      "member":     "private-base-override"
    }
  },
  "access-readonly-stack": {
    "description": "Information Channel",
    "profiles": {
      "@everyone":  "access-base-override",
      "muted":      "readonly-override",
      "member":     "readonly-override",
      "mod":        "mod-mod-override"
    }
  },
  "access-write-stack": {
    "description": "General Channel",
    "profiles": {
      "@everyone":  "access-base-override",
      "muted":      "readonly-override",
      "member":     "member-write-override",
      "mod":        "mod-mod-override",
      "admin":      "admin-admin-override"
    }
  },
  "access-private-stack": {
    "description": "Private Channel",
    "profiles": {
      "@everyone":  "private-base-override",
      "admin":      "admin-admin-override"
    }
  }
}
