{
  "chanPerms": {
    "stack": [
      "open-base-override",
      "private-base-override",
      "access-base-override",
      "member-write-override",
      "captain-mod-override",
      "mod-mod-override",
      "admin-admin-override"
    ],
    "open-base-override": {
      "description": [
        "Open Membership Base",
        "No invites"
      ],
      "profiles": {
        "open-base-override": {
          "CreateInstantInvite": false
        }
      }
    },
    "private-base-override": {
      "description": [
        "Private Channel Base",
        "No invites, can't view"
      ],
      "profiles": {
        "dependencies": [
          "open-base-override"
        ],
        "private-base-override": {
          "ViewChannel": false,
          "Connect": false
        }
      }
    },
    "access-base-override": {
      "description": [
        "Access Membership Base",
        "Alias for private-base-override"
      ],
      "profiles": {
        "dependencies": [
          "open-base-override",
          "private-base-override"
        ],
        "access-base-override": {}
      }
    },
    "readonly-override": {
      "description": [
        "Read-only Override",
        "Can view, connect"
      ],
      "profiles": {
        "dependencies": [
          "open-base-override",
          "private-base-override",
          "access-base-override"
        ],
        "readonly-override": {
          "ViewChannel": true,
          "Connect": true,
          "SendMessages": false,
          "SendMessagesInThreads": false,
          "CreatePublicThreads": false,
          "AddReactions": false,
          "Speak": false,
          "Stream": false
        }
      }
    },
    "access-welcome-stack": {
      "description": "Welcome Channel",
      "profiles": {
        "@everyone": "readonly-override",
        "muted": "private-base-override",
        "member": "private-base-override"
      }
    },
    "access-readonly-stack": {
      "description": "Information Channel",
      "profiles": {
        "@everyone": "access-base-override",
        "muted": "readonly-override",
        "member": "readonly-override"
      }
    },
    "access-write-stack": {
      "description": "General Channel",
      "profiles": {
        "@everyone": "access-base-override",
        "muted": "readonly-override"
      }
    },
    "access-private-stack": {
      "description": "Private Channel",
      "profiles": {
        "@everyone": "private-base-override"
      }
    }
  },
  "rolePerms": {
    "stack": [
      "role-everyone-override",
      "role-read-override",
      "role-member-override",
      "role-captain-override",
      "role-mod-override",
      "role-admin-override"
    ],
    "role-admin-override": {
      "profiles": {
        "role-admin-override": [
          "Administrator",
          "ViewChannel"
        ]
      }
    },
    "role-mod-override": {
      "profiles": {
        "dependencies": [
          "role-captain-override"
        ],
        "role-mod-override": [
          "SendTTSMessages",
          "CreateGuildExpressions",
          "ManageGuildExpressions",
          "ViewAuditLog",
          "SendVoiceMessages",
          "UseSoundboard",
          "UseExternalSounds",
          "UseEmbeddedActivities",
          "UseExternalApps",
          "ManageNicknames",
          "ModerateMembers",
          "BanMembers",
          "KickMembers",
          "MentionEveryone"
        ]
      }
    },
    "role-captain-override": {
      "profiles": {
        "role-captain-override": [
          "ManageMessages",
          "PinMessages",
          "SendPolls",
          "MuteMembers",
          "DeafenMembers",
          "MoveMembers",
          "CreateEvents",
          "ManageEvents"
        ]
      }
    },
    "role-member-override": {
      "profiles": {
        "role-member-override": [
          "SendMessagesInThreads",
          "CreatePublicThreads",
          "ChangeNickname",
          "AddReactions",
          "UseExternalEmojis",
          "UseExternalStickers",
          "Speak",
          "Stream",
          "UseApplicationCommands",
          "UseVAD",
          "EmbedLinks"
        ]
      }
    },
    "role-read-override": {
      "profiles": {
        "role-read-override": [
          "ViewChannel",
          "Connect"
        ]
      }
    },
    "role-everyone-override": {
      "profiles": {
        "role-everyone-override": [
          "SendMessages",
          "ReadMessageHistory"
        ]
      }
    },
    "role-access-stack": {
      "profiles": {
        "admin":      "role-admin-override",
        "mod":        "role-mod-override",
        "captain":    "role-captain-override",
        "member":     "role-member-override",
        "muted":      "role-read-override",
        "@everyone":  "role-everyone-override"
      }
    }
  }
}
