const { ApplicationCommandOptionType } = require('discord.js')
const weather = require('weather-js')

module.exports = class WeatherCommand extends RookCommand {
  constructor(client) {
    let comprops = {
      name: "weather",
      category: "info",
      description: "Weather",
      options: [
        {
          name: 'unit',
          description: 'Celsius or Fahrenheit',
          type: ApplicationCommandOptionType.String,
          choices: [
            {
              name: 'Celsius',
              value: 'C'
            },
            {
              name: 'Fahrenheit',
              value: 'F'
            }
          ],
          required: true
        },
        {
          name: 'location',
          description: 'Location to search for',
          type: ApplicationCommandOptionType.String,
          required: true
        }
      ]
    }
    let props = {}
    super(
      client,
      {...comprops},
      {...props}
    )
  }

  async action(client, interaction, coptions) {
    let degreeType = coptions.unit
    let search = coptions.location
    if (search == "") {
      error = true
      this.props.description = "Please specify a location."
      return
    }
    weather.find(
      {
        search: search,
        degreeType: degreeType
      }, await function(error, result) {
        if(error || !search || result === undefined || result.length === 0) {
          this.error = true
          if(error) {
            this.props.description = error
          } else if(!search) {
            this.props.description = "Please specify a location"
          } else if(result === undefined || result.length === 0) {
            this.props.description = "**Invalid** Location"
          } else {
            this.props.description = ""
          }
        } else {
          let current = result[0].current
          let location = result[0].location
          this.props.description = `**${current.skytext}**`
          this.props.caption.text = `Weather forecast for ${current.observationpoint}`
          this.props.players.bot.url = `https://www.accuweather.com/en/search-locations?query=` + encodeURI(`${current.observationpoint}`)
          this.props.players.user.avatar = current.imageUrl
          this.props.fields = [
            [
              {
                name: "Timezone",
                value: "UTC" + (parseInt(location.timezone) >= 0 ? '+' : "") + location.timezone
              },
              {
                name: "Degree Type",
                value: degreeType
              },
              {
                name: "Temperature",
                value: `${current.temperature}°${degreeType}`
              }
            ],
            [
              {
                name: "Wind",
                value: current.winddisplay
              },
              {
                name: "Feels Like",
                value: `${current.feelslike}°${degreeType}`
              },
              {
                name: "Humidity",
                value: `${current.humidity}%`
              }
            ]
          ]
        }
      }
    )
  }
}
