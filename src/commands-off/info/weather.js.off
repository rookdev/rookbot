// @ts-nocheck

import { RookCommand } from '../../classes/command/rcommand.class'

const { ApplicationCommandOptionType } = require('discord.js')
const weather = require('weather-js')

module.exports = class WeatherCommand extends RookCommand {
  constructor(client) {
    let comprops = {
      name: "weather",
      category: "info",
      description: "Weather",
      options: [
        {
          name: 'unit',
          description: 'Celsius or Fahrenheit',
          type: ApplicationCommandOptionType.String,
          choices: [
            {
              name: 'Celsius',
              value: 'C'
            },
            {
              name: 'Fahrenheit',
              value: 'F'
            }
          ],
          required: true
        },
        {
          name: 'location',
          description: 'Location to search for',
          type: ApplicationCommandOptionType.String,
          required: true
        }
      ]
    }
    let props = {}
    super(
      client,
      {...comprops},
      {...props}
    )
  }

  // declare props: import('../../types/embed').EmbedProps

  async action(client, interaction, coptions) {
    let degreeType = coptions.unit
    let search = coptions.location
    let error = false
    let props = this.props
    if (!props.title?.text) {
      // @ts-ignore
      props.title.text = ""
    }

    if (search == "") {
      this.error = true
      this.props.description = "Please specify a location."
      return false
    }
    weather.find(
      {
        search: search,
        degreeType: degreeType
      }, await function(wError, result) {
        if(wError || !search || result === undefined || result.length === 0) {
          error = true
          if(wError) {
            props.description = wError
          } else if(!search) {
            props.description = "Please specify a location"
          } else if(result === undefined || result.length === 0) {
            props.description = "**Invalid** Location"
          } else {
            props.description = ""
          }
        } else {
          let current = result[0].current
          let location = result[0].location
          props.description = `**${current.skytext}**`
          // @ts-ignore
          props.title.text = `Weather forecast for ${current.observationpoint}`
          props.players.bot.url = `https://www.accuweather.com/en/search-locations?query=` + encodeURI(`${current.observationpoint}`)
          props.players.user.avatar = current.imageUrl
          props.fields = [
            [
              {
                name: "Timezone",
                value: "UTC" + (parseInt(location.timezone) >= 0 ? '+' : "") + location.timezone
              },
              {
                name: "Degree Type",
                value: degreeType
              },
              {
                name: "Temperature",
                value: `${current.temperature}°${degreeType}`
              }
            ],
            [
              {
                name: "Wind",
                value: current.winddisplay
              },
              {
                name: "Feels Like",
                value: `${current.feelslike}°${degreeType}`
              },
              {
                name: "Humidity",
                value: `${current.humidity}%`
              }
            ]
          ]
        }
      }
    )

    this.props = props
    this.error = error

    return !this.error
  }
}
