// @ts-nocheck

const scheduleNicknameChange = require('../../utils/guild/scheduleNicknameChange')
const fileFuncs = require('../../utils/fs/fileFuncs')
const numFuncs = require('../../utils/primitives/numFuncs')
const getters = require('../../utils/guild/getters')
const path = require('path')

// natSort
function natSort(a, b) {
  return a.localeCompare(b, undefined, { numeric: true });
}

module.exports = async (client) => {
  let result = false
  let messages = []

  // Users to search for
  let nicknameDataPath = fileFuncs.getAPath(
    [
      "src",
      "dbs",
      "nicknames"
    ]
  )
  let userFiles = fileFuncs.getAllFiles(nicknameDataPath)
    // Filter JSON documents that are numeric
    .filter(
      (fileName) => fileName.endsWith(".json") &&
        numFuncs.myIsNumeric(
          fileName
            .split(path.sep)
            .slice(-1)[0]
            .substring(
              0,
              fileName
                .split(path.sep)
                .slice(-1)[0]
                .indexOf(".") - 1
            )
        )
    )
    // Strip .json extension
    .map(
      (fileName) => fileName.replace(".json","").trim()
    )
    // Skip first document
    .slice(1)
    .sort(natSort)

  // Cycle through users
  for(let userFile of userFiles) {
    let userID = userFile.split(path.sep).slice(-1)

    // Guilds to search in
    let guildFiles = fileFuncs.getAllFiles(
      [
        "src",
        "dbs"
      ],
      true
    )
      // Filter folders that are numeric
      .filter(
        (fileName) => numFuncs.myIsNumeric(
          fileName
            .split(path.sep)
            .slice(-1)[0]
        )
      )
      .sort(natSort)

    // Cycle through guilds
    for(let guildFile of guildFiles) {
      let guildID = guildFile.split(path.sep).slice(-1)
      // Find the guild
      let guild = await getters.getCache(client, client, "guilds", guildID)
      if (!guild) {
        messages.push(`${client.profile.emojis.fail} Failed to load guild [${guildID}]`)
        continue
      }

      messages.push("Finding User Member!")
      // Get the guild member
      let member = await getters.getCache(client, guild, "members", userID)
      if (!member) {
        messages.push(`${client.profile.emojis.fail} Failed to load guild members [${guildID}]`)
        continue
      }
      messages.push("Found User Member!")

      // If guild owner, bail
      if (member.guild.ownerId === member.id) {
        messages.push(`${client.profile.emojis.fail} No  scheduled nickname changes for '${member.user.tag}' in '${member.guild.name}'. '${member.user.tag}' is server owner.`)
        continue
      }

      messages.push("Finding Client Member!")
      // Get the client member
      const clientMember  = guild.members.me
      const clientPos     = await clientMember.roles.highest.position
      const memberPos     = await member.roles.highest.position
      messages.push("Found Client Member!")

      // If member is at or over bot, bail
      if ((clientMember.id !== member.id) && (memberPos >= clientPos)) {
        messages.push(`${client.profile.emojis.fail} No  scheduled nickname changes for '${member.user.tag}' in '${member.guild.name}'. '${member.user.tag}' is greater than or equal to '${clientMember.displayName}'.`)
        continue
      }

      if (member) {
        // If we got here, schedule the nickname change
        let [thisResult, thisMessages] = await scheduleNicknameChange(client, member)
        result = thisResult
        messages = messages.concat(thisMessages)
      }
    }
  }

  return [result, messages]
}
