// @ts-nocheck
const { GuildMember } = require('discord.js')
const { RookClient } = require('../../classes/objects/rclient.class')
const logMemberJoin = require('../guildMemberAdd/logMemberJoin')
const moment = require('moment')

/**
 * Logs when a new member joins the server and saves it to a log file.
 * @param {RookClient} client
 * @param {GuildMember} oldMember
 * @param {GuildMember} newMember
 */
module.exports = async (client, oldMember, newMember) => {
  let result = false
  let messages = []

  if (oldMember.roles !== newMember.roles) {
    let eventTime = moment()
    oldRoles = await oldMember.roles.cache.map(r => r.name).join(", ")
    newRoles = await newMember.roles.cache.map(r => r.name).join(", ")
    if (!oldRoles.includes("Member") && newRoles.includes("Member")) {
      [result, messages] = logMemberJoin(client, newMember)
    }
  }

  return [result, messages]
}
